# Vapi PRIVATE API key (Org Settings > API Keys > Private Key) — NOT the public
# key. Server-side REST calls like creating an outbound call require the private
# key; the public key returns 401. Both look like 36-char UUIDs.
VAPI_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Vapi phone number ID (outbound caller number) — get from Vapi dashboard > Numbers
VAPI_PHONE_NUMBER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Google AI Studio API key — get from https://aistudio.google.com/apikey
# Used to call Gemini Flash-Lite via Vapi's custom-LLM (OpenAI-compatible) endpoint
GOOGLE_AI_STUDIO_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxxx

# Target phone number — the Pretty Good AI agent under test
TARGET_PHONE_NUMBER=+18054398008
